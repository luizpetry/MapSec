# ReconX Environment Variables

# VirusTotal API key (required for vt plugin)
# Get yours at: https://www.virustotal.com/gui/my-apikey
VT_API_KEY=your_virustotal_api_key_here

# Optional: Shodan API key (for future plugins)
# SHODAN_API_KEY=

# Optional: AbuseIPDB API key (for future plugins)
# ABUSEIPDB_API_KEY=
